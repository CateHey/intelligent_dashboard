# ─────────────────────────────────────────────────────────────
# Copiar a .env.local y completar. NUNCA subir .env.local a git.
#
# DEMO LOCAL: si NO ponés nada de esto, la app arranca sola en MODO DEMO
# (Postgres embebido PGlite con 220 jobs sembrados + traductor local).
#   npm run dev  →  http://localhost:3000
# Forzarlo explícitamente: DEMO_MODE=1
# ─────────────────────────────────────────────────────────────

# DEMO_MODE=1

# Supabase (proyecto Inti)
SUPABASE_URL=https://qvtwcpnbcfjwylpawbkb.supabase.co
# service_role: SOLO en el server. Se usa para log/cache y para llamar exec_read_sql.
# La lectura de datos de Claude NO corre con este rol: corre dentro de exec_read_sql
# con el rol restringido dashboard_readonly (ver sql/04_role_exec.sql).
SUPABASE_SERVICE_ROLE_KEY=

# Claude
ANTHROPIC_API_KEY=
# Modelos disponibles: claude-sonnet-4-6 (recomendado), claude-haiku-4-5-20251001 (más barato), claude-opus-4-8
ANTHROPIC_MODEL=claude-sonnet-4-6

# Tenant fijo (Inti). Cuando se meta multi-tenant, sale del JWT, no de acá.
TENANT_ID=ddec3ab2-ec58-46c8-912c-1d1cd00cae86

# Rate limit: preguntas por minuto por tenant
RATE_LIMIT_PER_MIN=20

# (Opcional) Realtime en el front. Anon key pública. Requiere RLS para producción.
# NEXT_PUBLIC_SUPABASE_URL=https://qvtwcpnbcfjwylpawbkb.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
